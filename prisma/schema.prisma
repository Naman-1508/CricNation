generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  phone         String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("PLAYER") // PLAYER, ORGANIZER, UMPIRE, FAN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teamsCaptain  Team[]    @relation("TeamCaptain")
  teams         TeamMember[]
  tournaments   Tournament[]
  feedPosts     FeedPost[]
  comments      Comment[]
  likes         Like[]
  matchesUmpired Match[]  @relation("MatchUmpire")
  
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Follower")
  notifications Notification[]
  awards        Award[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  city        String?
  jerseyColor String?
  captainId   String
  captain     User     @relation("TeamCaptain", fields: [captainId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  matchesHome Match[]  @relation("HomeTeam")
  matchesAway Match[]  @relation("AwayTeam")
  tournaments TournamentTeam[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("PLAYER") // CAPTAIN, VC, PLAYER
  user      User     @relation(fields: [userId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([userId, teamId])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  format      String   // T10, T20, ODI, TEST
  bracketType String   // LEAGUE_KNOCKOUT, ROUND_ROBIN
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED
  createdAt   DateTime @default(now())

  teams       TournamentTeam[]
  matches     Match[]
  leaderboard Leaderboard[]
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  status       String     @default("REGISTERED") // REGISTERED, APPROVED, REJECTED
  points       Int        @default(0)
  nrr          Float      @default(0)
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}

model Match {
  id             String      @id @default(cuid())
  tournamentId   String?
  homeTeamId     String
  awayTeamId     String
  groundId       String?
  umpireId       String?
  tossWinnerId   String?
  tossDecision   String?     // BAT, BOWL
  status         String      @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED
  overs          Int         @default(20)
  result         String?
  startTime      DateTime
  
  tournament     Tournament? @relation(fields: [tournamentId], references: [id])
  homeTeam       Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  ground         Ground?     @relation(fields: [groundId], references: [id])
  umpire         User?       @relation("MatchUmpire", fields: [umpireId], references: [id])
  
  innings        Innings[]
}

model Innings {
  id             String   @id @default(cuid())
  matchId        String
  teamId         String
  inningsNumber  Int
  totalRuns      Int      @default(0)
  totalWickets   Int      @default(0)
  overs          Float    @default(0)
  isCompleted    Boolean  @default(false)
  
  match          Match    @relation(fields: [matchId], references: [id])
  
  balls          BallByBall[]
  scorecards     Scorecard[]
}

model BallByBall {
  id             String   @id @default(cuid())
  inningsId      String
  overNumber     Int
  ballNumber     Int
  batterId       String
  bowlerId       String
  runs           Int      @default(0)
  isWide         Boolean  @default(false)
  isNoBall       Boolean  @default(false)
  isLegBye       Boolean  @default(false)
  isBye          Boolean  @default(false)
  isWicket       Boolean  @default(false)
  dismissalType  String?  // BOWLED, CAUGHT, LBW, RUN_OUT, STUMPED
  dismissedId    String?
  fielderId      String?
  timestamp      DateTime @default(now())

  innings        Innings  @relation(fields: [inningsId], references: [id])
}

model Scorecard {
  id             String   @id @default(cuid())
  inningsId      String
  playerId       String
  runs           Int      @default(0)
  ballsFaced     Int      @default(0)
  fours          Int      @default(0)
  sixes          Int      @default(0)
  isOut          Boolean  @default(false)
  dismissalInfo  String?
  oversBowled    Float    @default(0)
  runsConceded   Int      @default(0)
  wickets        Int      @default(0)
  maidens        Int      @default(0)

  innings        Innings  @relation(fields: [inningsId], references: [id])
}

model Ground {
  id          String   @id @default(cuid())
  name        String
  address     String
  latitude    Float
  longitude   Float
  matches     Match[]
}

model FeedPost {
  id          String    @id @default(cuid())
  userId      String
  content     String
  mediaUrl    String?
  matchId     String?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  comments    Comment[]
  likes       Like[]
}

model Comment {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  post        FeedPost @relation(fields: [postId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Like {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  
  post        FeedPost @relation(fields: [postId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String

  follower    User     @relation("Follower", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Leaderboard {
  id             String     @id @default(cuid())
  tournamentId   String
  playerId       String
  runs           Int        @default(0)
  wickets        Int        @default(0)
  points         Int        @default(0)

  tournament     Tournament @relation(fields: [tournamentId], references: [id])
}

model Award {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  awardedAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}
