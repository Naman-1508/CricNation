generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum TeamRole {
  CAPTAIN
  VICE_CAPTAIN
  PLAYER
}

enum RegStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  phone         String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  city          String?
  role          String    @default("PLAYER") // PLAYER, ORGANIZER, UMPIRE, FAN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teamsCreated    Team[]          @relation("TeamCreatedBy")
  teamMemberships TeamMember[]
  tournaments     Tournament[]    @relation("TournamentOrganizer")
  feedPosts       FeedPost[]
  comments        Comment[]
  likes           Like[]
  matchesUmpired  Match[]         @relation("MatchUmpire")
  matchPlayers    MatchPlayer[]
  followers       Follow[]        @relation("Following")
  following       Follow[]        @relation("Follower")
  notifications   Notification[]
  awards          Award[]
  registrations   TournamentRegistration[]

  accounts        Account[]
  sessions        Session[]
}

// ─────────────────────────────────────────────────────────────
// AUTH (NextAuth)
// ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  shortName   String   @db.VarChar(5)
  colorHex    String   @default("#10b981")
  logoUrl     String?
  homeGround  String?
  city        String?
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("TeamCreatedBy", fields: [createdById], references: [id])

  members       TeamMember[]
  homeMatches   Match[]                  @relation("HomeTeam")
  awayMatches   Match[]                  @relation("AwayTeam")
  tournaments   TournamentTeam[]
  matchPlayers  MatchPlayer[]
  registrations TournamentRegistration[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String?
  phone     String?
  name      String
  role      TeamRole @default(PLAYER)
  jerseyNo  Int?
  joinedAt  DateTime @default(now())

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT
// ─────────────────────────────────────────────────────────────

model Tournament {
  id                 String   @id @default(cuid())
  name               String
  logo               String?
  format             String   // T10, T20, ODI, TEST
  bracketType        String   @default("LEAGUE_KNOCKOUT")
  organizerId        String
  organizer          User     @relation("TournamentOrganizer", fields: [organizerId], references: [id])
  startDate          DateTime
  endDate            DateTime?
  status             String   @default("UPCOMING")
  registrationOpen   Boolean  @default(true)
  maxTeams           Int      @default(16)
  entryFee           Int      @default(0)
  registrationDeadline DateTime?
  autoApprove        Boolean  @default(false)
  shareCode          String   @unique @default(cuid())
  createdAt          DateTime @default(now())

  teams         TournamentTeam[]
  matches       Match[]
  leaderboard   Leaderboard[]
  registrations TournamentRegistration[]
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  status       String     @default("REGISTERED")
  points       Int        @default(0)
  nrr          Float      @default(0)
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}

model TournamentRegistration {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  status       RegStatus  @default(PENDING)
  registeredAt DateTime   @default(now())
  registeredBy String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])
  registrant   User       @relation(fields: [registeredBy], references: [id])

  @@unique([tournamentId, teamId])
}

// ─────────────────────────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────────────────────────

model Match {
  id             String   @id @default(cuid())
  tournamentId   String?
  homeTeamId     String
  awayTeamId     String
  groundName     String?
  umpireId       String?
  tossWinnerId   String?
  tossDecision   String?  // BAT, BOWL
  status         String   @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED
  overs          Int      @default(20)
  ballType       String   @default("Leather")
  matchType      String   @default("LIMITED_OVERS") // LIMITED_OVERS, UNLIMITED
  result         String?
  startTime      DateTime @default(now())
  createdById    String?

  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  umpire       User?       @relation("MatchUmpire", fields: [umpireId], references: [id])
  innings      Innings[]
  matchPlayers MatchPlayer[]
}

model MatchPlayer {
  id        String  @id @default(cuid())
  matchId   String
  teamId    String
  userId    String?
  name      String
  jerseyNo  Int?
  isPlaying Boolean @default(true)
  isBatted  Boolean @default(false)
  isBowled  Boolean @default(false)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  battingBalls  BallByBall[] @relation("BatsmanBalls")
  bowlingBalls  BallByBall[] @relation("BowlerBalls")
}

// ─────────────────────────────────────────────────────────────
// INNINGS & BALL BY BALL
// ─────────────────────────────────────────────────────────────

model Innings {
  id            String  @id @default(cuid())
  matchId       String
  teamId        String
  inningsNumber Int
  totalRuns     Int     @default(0)
  totalWickets  Int     @default(0)
  overs         Float   @default(0)
  isCompleted   Boolean @default(false)

  match      Match        @relation(fields: [matchId], references: [id])
  balls      BallByBall[]
  scorecards Scorecard[]
}

model BallByBall {
  id            String    @id @default(cuid())
  inningsId     String
  overNumber    Int
  ballNumber    Int
  batsmanId     String
  bowlerId      String
  runs          Int       @default(0)
  isWide        Boolean   @default(false)
  isNoBall      Boolean   @default(false)
  isLegBye      Boolean   @default(false)
  isBye         Boolean   @default(false)
  isWicket      Boolean   @default(false)
  dismissalType String?   // BOWLED, CAUGHT, LBW, RUN_OUT, STUMPED
  dismissedId   String?
  fielderId     String?
  timestamp     DateTime  @default(now())
  deletedAt     DateTime?
  undoneBy      String?

  innings  Innings     @relation(fields: [inningsId], references: [id])
  batsman  MatchPlayer @relation("BatsmanBalls", fields: [batsmanId], references: [id])
  bowler   MatchPlayer @relation("BowlerBalls", fields: [bowlerId], references: [id])
}

model Scorecard {
  id            String  @id @default(cuid())
  inningsId     String
  playerId      String
  runs          Int     @default(0)
  ballsFaced    Int     @default(0)
  fours         Int     @default(0)
  sixes         Int     @default(0)
  isOut         Boolean @default(false)
  dismissalInfo String?
  oversBowled   Float   @default(0)
  runsConceded  Int     @default(0)
  wickets       Int     @default(0)
  maidens       Int     @default(0)

  innings Innings @relation(fields: [inningsId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// SOCIAL
// ─────────────────────────────────────────────────────────────

model FeedPost {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mediaUrl  String?
  matchId   String?
  isAutoPost Boolean @default(false)
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]
  likes    Like[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post FeedPost @relation(fields: [postId], references: [id])
  user User     @relation(fields: [userId], references: [id])
}

model Like {
  id     String @id @default(cuid())
  postId String
  userId String

  post FeedPost @relation(fields: [postId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

// ─────────────────────────────────────────────────────────────
// MISC
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Leaderboard {
  id           String     @id @default(cuid())
  tournamentId String
  playerId     String
  runs         Int        @default(0)
  wickets      Int        @default(0)
  points       Int        @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model Award {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  awardedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
